--  pkg.ads
package Pkg is
   My_Constant : constant Integer := 42;
   procedure Do_Something;
end Pkg;

--  pkg.adb
package body Pkg is
   procedure Do_Something is
   begin
      null;
   end Do_Something;
end Pkg;

--  main.adb
with Pkg;

procedure Main is
   X : Integer := Pkg.My_Constant;
begin
   Pkg.Do_Something;
end Main;

